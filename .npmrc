# Vercel-compatible pnpm configuration for monorepo
# Allow Next.js tooling (postcss, tailwind, eslint) to be hoisted
shamefully-hoist=false
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=@next/eslint-plugin-next
public-hoist-pattern[]=*postcss*
public-hoist-pattern[]=*tailwindcss*
public-hoist-pattern[]=*autoprefixer*

# Reproducible installs
auto-install-peers=true
strict-peer-dependencies=false

# Do NOT use package-manager-strict on Vercel — corepack version may differ
# package-manager-strict=true

# Monorepo: link workspace packages instead of fetching from registry
link-workspace-packages=true
